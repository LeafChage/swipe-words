{
  "name": "bun-react-template",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --hot src/index.ts",
    "dev:obsidian": "bun --watch build.ts",
    "build": "bun run build:ts && bun run build:css",
    "build:ts": "bun run ./build.ts",
    "build:css": "tailwindcss -i ./src/index.css -o ./styles.css"
  },
  "dependencies": {
    "bulma": "^1.0.4",
    "obsidian": "^1.12.3",
    "react": "^19",
    "react-dom": "^19"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.4",
    "@types/bun": "latest",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "bun-plugin-tailwind": "^0.1.2",
    "tailwindcss": "^4.2.4"
  }
}
