{
  "name": "bun-react-template",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --watch build.ts",
    "build": "bun run build:ts && bun run build:css",
    "build:release": "NODE_ENV=development bun run build && bun run package",
    "build:ts": "bun run ./build.ts",
    "build:css": "tailwindcss -i ./src/index.css -o ./dist/styles.css",
    "package": "zip -j swipe-card.zip dist/main.js dist/main.css dist/styles.css manifest.json"
  },
  "dependencies": {
    "bulma": "^1.0.4",
    "date-fns": "^4.4.0",
    "obsidian": "^1.12.3",
    "react": "^19",
    "react-dom": "^19"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.4",
    "@types/bun": "latest",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "bun-plugin-tailwind": "^0.1.2",
    "tailwindcss": "^4.2.4"
  }
}
